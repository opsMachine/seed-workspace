# ─────────────────────────────────────────────────────────────────────
# transcript-vault-mcp — environment
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────

# Which recorder adapter to use. See adapters/README.md.
# Default: fathom. Other shipped stubs: otter, granola, fireflies.
RECORDER_ADAPTER=fathom

# Where the corpus lives. Defaults to this repo root if unset, so a
# fresh clone keeps working with no env setup.
#
# Recommended: point at the parent workspace's vault folder so the
# corpus and your strategy artifacts live in one place:
#
#   VAULT_DATA_ROOT=/home/you/Documents/GitHub/seed-workspace/vault
#
# (Legacy alias: FATHOM_DATA_ROOT — still honored for back-compat.)
VAULT_DATA_ROOT=

# ─────────────────────────────────────────────────────────────────────
# Adapter-specific keys (set what you need)
# ─────────────────────────────────────────────────────────────────────

# Fathom — issue from https://app.fathom.video/settings/integrations
FATHOM_API_KEY=

# Fireflies — issue from https://app.fireflies.ai/settings/developer
FIREFLIES_API_KEY=

# Otter — set if you have a working API key OR use the export-folder path
OTTER_API_KEY=
OTTER_EXPORT_DIR=

# Granola — typically reads from the local on-disk store
GRANOLA_LOCAL_STORE=
